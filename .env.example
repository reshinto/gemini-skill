# Canonical local mirror of the gemini-skill Claude settings env block.
# Resolution order at runtime:
#   1. ./.env
#   2. ./.claude/settings.local.json
#   3. ./.claude/settings.json
#   4. ~/.claude/settings.json
#   5. existing process environment

# Gemini API key (required for real API calls)
GEMINI_API_KEY=

# Prefer the google-genai SDK transport first
GEMINI_IS_SDK_PRIORITY=true

# Prefer raw HTTP first only when you intentionally invert backend priority
GEMINI_IS_RAWHTTP_PRIORITY=false

# Enable live integration tests against the real API
GEMINI_LIVE_TESTS=0
