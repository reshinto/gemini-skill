# Gemini API key (required — get one at https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Alternative env var name (optional — if set, takes precedence over GEMINI_API_KEY)
# GOOGLE_API_KEY=

# Enable live integration tests (optional, dev use only)
# Runs tests/integration/*.py against the real Gemini API.
# GEMINI_LIVE_TESTS=1

# Extra opt-in for billable image generation against the real API
# (only relevant alongside GEMINI_LIVE_TESTS=1). Gates
# tests/integration/test_image_gen_real_live.py so it never runs
# accidentally as part of the normal live suite.
GEMINI_LIVE_IMAGE_GEN=1

# Enable recording of live API responses as test fixtures (optional, dev use only)
# GEMINI_RECORD_MOCKS=1
