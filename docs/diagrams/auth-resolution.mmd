%% Runtime env bootstrap precedence for canonical Gemini keys.
%% The launcher resolves config from the current working directory, then
%% writes the selected values into os.environ before auth/config code runs.
flowchart TD
    START([launcher starts])
    DOTENV["./.env"]
    LOCAL["./.claude/settings.local.json"]
    SHARED["./.claude/settings.json"]
    GLOBAL["~/.claude/settings.json"]
    PROCESS["existing process env"]
    BOOTSTRAP([bootstrap_runtime_env])
    OSENV["os.environ"]
    AUTH{"GEMINI_API_KEY set?"}
    RETURN_KEY([return key])
    ERROR[/"raise AuthError"/]
    NOTE["Only canonical keys are imported.<br/>GOOGLE_API_KEY is ignored."]

    DOTENV --> BOOTSTRAP
    LOCAL --> BOOTSTRAP
    SHARED --> BOOTSTRAP
    GLOBAL --> BOOTSTRAP
    PROCESS --> BOOTSTRAP
    START --> BOOTSTRAP
    BOOTSTRAP --> OSENV
    OSENV --> AUTH
    AUTH -->|yes| RETURN_KEY
    AUTH -->|no| ERROR
    NOTE -.-> BOOTSTRAP
