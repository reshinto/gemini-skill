%% End-to-end install pipeline shared by gemini-skill-install and setup/install.py.
flowchart TD
    START{Install entry point}
    BOOT["uvx / pipx<br/>gemini-skill-install"]
    MAT[Materialize packaged payload<br/>to a temp directory]
    CLONE["python3 setup/install.py<br/>(clone or release tarball)"]
    PYTHON[Validate stable CPython 3.9+<br/>and re-exec if needed]
    SOURCE[Resolve shared install payload]
    COPY[Copy runtime payload to<br/>~/.claude/skills/gemini/]
    CHK[Write .checksums.json<br/>install manifest]
    VENV[Create or reuse<br/>~/.claude/skills/gemini/.venv]
    PIP["pip install -r setup/requirements.txt<br/>(google-genai==1.33.0 pinned)"]
    VERIFY[Import google.genai<br/>confirm SDK usable]
    KEY[Prompt / merge env block into<br/>~/.claude/settings.json]
    DONE([Install complete])

    START --> BOOT --> MAT --> SOURCE
    START --> CLONE --> PYTHON --> SOURCE
    SOURCE --> COPY --> CHK --> VENV --> PIP --> VERIFY --> KEY --> DONE

    classDef new fill:#e1f5ff,stroke:#0277bd,stroke-width:2px
    class MAT,PYTHON,CHK,VENV,PIP,VERIFY,KEY new
